# Unity .gitignore
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# Autogenerated VS/MD files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj

# Unity3D generated meta files
*.pidb.meta

# Unity3D Generated File On Crash Reports
sysinfo.txt

# Builds
*.apk
*.unitypackage

# Visual Studio
.vs/

# Rider
.idea/

# macOS
.DS_Store

# Windows
Thumbs.db

# Локальные настройки (не коммитить!)
Config/local*.json
Secrets/
Personal/

# OpenClaw временные файлы
.openclaw/cache/
.openclaw/tmp/

# Мониторинг данные
prometheus_data/
grafana/data/

# Логи
logs/

# Временные скрипты
*.sh.bak
*.py.bak

# Файлы с паролями/ключами
*_password*
*_secret*
*_key*
*_token*
